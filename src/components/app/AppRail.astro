---
import { t } from 'i18next'
const currentPath = Astro.url.pathname;

type RailItem = {
  label?: string;
  href: string;
  icon: string;
};

const rail: Array<RailItem> = [
  {
    href: '/',
    icon: 'veil-advance',
  },
  {
    href: '/sites',
    icon: 'mekanismi',
    label: t('navigation:sites')
  }
];
---
<nav class="rail">
  {
    rail.map((item) => {
      const isActive = currentPath === item.href;
      return (
        <a href={item.href}>
          <cn-navigation-icon
            !active = {isActive}
            noun={item.icon}
            label={item.label}
            checked={currentPath === item.href}
          />
        </a>
      );
    })
  }
</nav>
