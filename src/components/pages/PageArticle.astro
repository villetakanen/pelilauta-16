---
import { db } from '../../firebase/server'
import { PageSchema } from '../../schema/Page'
import { extractFlowTime } from '../../firebase/helpers'
import { marked } from 'marked'

interface Props {
  sitekey: string
  pagekey: string
}
const { sitekey, pagekey } = Astro.props

const pageRef = db
  .collection('sites')
  .doc(sitekey)
  .collection('pages')
  .doc(pagekey)
const pageDoc = await pageRef.get()
const page = PageSchema.parse({
  ...pageDoc.data(),
  key: pagekey,
  parentKey: sitekey,
  flowTime: extractFlowTime(pageDoc.data()),
})
const content = page.markdownContent ? marked.parse(page.markdownContent || '') : page.htmlContent
---

<article set:html={content} class="large-width"/>
